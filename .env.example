# SentriX Server Environment Variables

# Anthropic API Key (required for the AI compliance pipeline agents; local analysis fallback runs when unset)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
# Optional pipeline model overrides
# ANTHROPIC_MODEL=claude-sonnet-5
# ANTHROPIC_COMPLEX_MODEL=claude-fable-5

# Groq Cloud API Key (used by the compliance copilot, hybrid clause scoring, and chat endpoints)
GROQ_API_KEY=gsk_your-groq-api-key-here

# OmniAgent orchestration layer (optional; local scoring fallback remains available when unset)
GENW_API_BASE_URL=https://genw.example.com
GENW_API_KEY=genw_your_api_key_here
GENW_TIMEOUT_MS=45000
GENW_HEALTH_ENDPOINT=/health

# Server Port
PORT=3001

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# PostgreSQL persistence (optional; when unset the server continues using in-memory runtime storage only)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/SentriX
# PGSSL=require
